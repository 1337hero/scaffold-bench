{
  "name": "scaffold-bench",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "bench": "bun bench.ts",
    "local": "bun bench.ts --runtime local",
    "web": "bun web.ts",
    "dev": "bun scripts/dev.ts",
    "dev:api": "bun web.ts",
    "dev:ui": "cd web-ui && bun run dev",
    "build:ui": "cd web-ui && bun run build",
    "start": "bun run build:ui && bun web.ts",
    "report": "bun report.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test test/"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "effect": "^3.21.2",
    "hono": "^4.12.15"
  }
}
