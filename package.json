{
  "name": "scaffold-bench",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "bun scripts/dev.ts",
    "bench:all": "bun scripts/run-all-models.ts",
    "build": "cd web-ui && bun run build",
    "start": "test -d web-ui/dist || bun run build && bun scripts/web.ts",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --report-unused-disable-directives",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "bun test test/"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "typescript": "5.9.3"
  },
  "dependencies": {
    "effect": "^3.21.2",
    "hono": "^4.12.15"
  }
}
