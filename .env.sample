# Local model server (Ollama, llama.cpp, llama-swap, LM Studio, vLLM, ...).
# Probed for /v1/models — anything it lists shows up in the modal.
# Default: http://127.0.0.1:8082
SCAFFOLD_LOCAL_ENDPOINT=http://127.0.0.1:8082

# Remote provider (any OpenAI-compatible endpoint: OpenRouter, Together, ...).
# All three must be set for remote models to appear.
SCAFFOLD_REMOTE_ENDPOINT=https://openrouter.ai/api
SCAFFOLD_REMOTE_API_KEY=sk-or-...
SCAFFOLD_REMOTE_MODELS=x-ai/grok-4.1-fast,anthropic/claude-3.5-sonnet,google/gemini-2.0-flash

# Web UI port (default 4317)
SCAFFOLD_WEB_PORT=4317
